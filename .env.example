# ============================================================================
# Casa DF — Variáveis de Ambiente (Coolify / Produção / VPS Google Cloud)
# ============================================================================
# Copie este arquivo para .env (local) ou cole os valores direto nas
# "Environment Variables" do serviço no Coolify. NUNCA commite o .env real.
#
# Legenda:
#   [NOVO OBRIGATÓRIO]   -> tem que ser um valor NOVO, diferente da Destrava
#   [REUTILIZAR]         -> pode usar o mesmo valor já configurado na Destrava
#   [DECISÃO SUA]        -> depende se você quer compartilhar ou segregar
#   [OPCIONAL]           -> só se for usar aquele recurso
# ============================================================================


# ── Banco de dados (PostgreSQL) ─────────────────────────────────────────────
#
# COOLIFY — PostgreSQL interno:
#   1. No Coolify, adicione um serviço "PostgreSQL" ao mesmo projeto.
#   2. O Coolify gera automaticamente a variável DATABASE_URL no serviço
#      da aplicação (não precisa preencher manualmente).
#   3. A conexão é pela rede interna Docker — SEM SSL, SEM porta externa.
#   4. DATABASE_SSL=false (já é o padrão detectado pelo código).
#
# Formato quando configurado manualmente:
#   postgresql://usuario:senha@hostname:5432/banco
#
# OBS: Se estiver usando Supabase/AWS/Neon/Render → SSL é detectado
# automaticamente. Não precisa de DATABASE_SSL=true para esses.

DATABASE_URL=postgresql://postgres:SENHA@HOST:5432/postgres
DATABASE_SSL=false

# [OPCIONAL] Ajuste do pool de conexões (Coolify PG interno suporta mais)
POOL_MAX=15
POOL_IDLE_TIMEOUT=30000
POOL_CONNECTION_TIMEOUT=5000


# ── Autenticação ─────────────────────────────────────────────────────────────

# [NOVO OBRIGATÓRIO] Segredo JWT para tokens de login.
# Gere um novo: openssl rand -hex 32
JWT_SECRET=

# [DECISÃO SUA] Segredos de integração (Nexus Gestão, etc.)
INTEGRATION_SECRET=
NEXUS_INTEGRATION_SECRET=
NEXUS_DESTRAVA_INTEGRATION_SECRET=


# ── Domínio e URLs ───────────────────────────────────────────────────────────

# [NOVO OBRIGATÓRIO] Domínio público do Casa DF
SITE_DOMAIN=casadf.com.br
FRONTEND_URL=https://casadf.com.br


# ── Armazenamento de arquivos ────────────────────────────────────────────────

# [COOLIFY] Pasta persistente. O Dockerfile define DATA_DIR=/var/data/casadf.
# IMPORTANTE: No Coolify, configure um VOLUME PERSISTENTE apontando para
# /var/data/casadf. Sem isso, fotos e PDFs se perdem em cada deploy/restart.
DATA_DIR=/var/data/casadf


# ── PDF (Puppeteer/Chromium) ─────────────────────────────────────────────────
# [JÁ VEM NO DOCKERFILE] Não precisa alterar.
CHROMIUM_PATH=/usr/bin/chromium


# ── IA (Gemini + OpenAI fallback) ────────────────────────────────────────────

# [REUTILIZAR] Pode usar a mesma chave Gemini da Destrava.
GEMINI_API_KEY=
GEMINI_API_URL=

# [NOVO] Fallback OpenAI para alta disponibilidade da IA.
OPENAI_API_KEY=
OPENAI_API_BASE=


# ── Consulta de CNPJ ─────────────────────────────────────────────────────────

# [REUTILIZAR]
CNPJ_API_TIMEOUT_MS=8000
CNPJ_ENABLE_OPENCNPJ=true
CPFCNPJ_ENABLED=true
OPENCNPJ_BASE_URL=


# ── Chatwoot (atendimento/WhatsApp) ──────────────────────────────────────────

# [DECISÃO SUA] Reutilize os valores da Destrava ou crie inbox separado.
CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_WEBHOOK_SECRET=


# ── n8n (automações) ─────────────────────────────────────────────────────────

# URL do webhook do workflow n8n que recebe eventos do Casa DF.
N8N_WEBHOOK_URL=


# ── Serviço de predição (opcional) ───────────────────────────────────────────

PREDICAO_SERVICE_URL=


# ── Infra geral ───────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000


# ── Variáveis de FRONTEND (Vite) — BUILD TIME ────────────────────────────────
# Estas variáveis precisam estar disponíveis no momento do `vite build`.
# No Coolify, configure-as como "Build Variables" ou "Build Args" no serviço.

VITE_APP_TITLE=Casa DF
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
