# Casa DF — referência completa de variáveis
# Copie somente os valores necessários para o Coolify. Não commite segredos.

# Obrigatórias em runtime
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/BANCO
JWT_SECRET=GERE_COM_OPENSSL_RAND_HEX_32

# Banco
DATABASE_SSL=false
POOL_MAX=10
POOL_IDLE_TIMEOUT=30000
POOL_CONNECTION_TIMEOUT=5000

# Aplicação
NODE_ENV=production
PORT=4000
SITE_DOMAIN=casadf.com.br
FRONTEND_URL=https://casadf.com.br
DATA_DIR=/var/data/casadf
UPLOAD_DIR=/var/data/casadf/uploads
# Deixe vazio para usar @sparticuz/chromium, já incluído no projeto.
CHROMIUM_PATH=
RUN_MIGRATIONS_ON_START=false

# Segurança e integrações internas
ENABLE_ADMIN_SQL=false
INTEGRATION_SECRET=
NEXUS_INTEGRATION_SECRET=
NEXUS_DESTRAVA_INTEGRATION_SECRET=

# IA — opcionais; o sistema principal sobe sem estas chaves
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_URL=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-pro
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_INLINE_BYTES=20971520
GEMINI_DOCUMENT_OCR_ENABLED=false
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini

# Consulta CNPJ pública
CNPJ_API_TIMEOUT_MS=8000
CNPJ_ENABLE_OPENCNPJ=true
OPENCNPJ_BASE_URL=https://api.opencnpj.org

# Provedores CPF/CNPJ pagos — opcionais
CPFCNPJ_ENABLED=false
CPFCNPJ_TOKEN=
CPFCNPJ_API_KEY=
CPFCNPJ_API_URL=
CPFCNPJ_CNPJ_PACKAGE=6
CPFCNPJ_TIMEOUT_MS=60000
CPFHUB_API_KEY=
CPFHUB_API_URL=
CPFHUB_TIMEOUT_MS=10000

# Chatwoot / WhatsApp — opcionais
CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_WEBHOOK_SECRET=

# Automação e previsão — opcionais
N8N_WEBHOOK_URL=
PREDICAO_SERVICE_URL=

# Frontend Vite — definidas no build
VITE_APP_TITLE=Casa DF
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Somente para `pnpm create-user`; não configure globalmente no serviço
NOME=
EMAIL=
SENHA=
CARGO=
