# ============================================================================
# Casa DF — Variáveis de Ambiente (Coolify / Produção)
# ============================================================================
# Copie este arquivo para .env (local) ou cole os valores direto nas
# "Environment Variables" do serviço no Coolify. NUNCA commite o .env real.
#
# Legenda:
#   [NOVO OBRIGATÓRIO]   -> tem que ser um valor NOVO, diferente da Destrava
#   [REUTILIZAR]         -> pode usar o mesmo valor já configurado na Destrava
#   [DECISÃO SUA]        -> depende se você quer compartilhar ou segregar
#   [OPCIONAL]           -> só se for usar aquele recurso
# ============================================================================


# ── Banco de dados ───────────────────────────────────────────────────────────

# [NOVO OBRIGATÓRIO] String de conexão do Postgres do Casa DF.
# Se for Supabase: Project Settings → Database → Connection string → modo
# "Session" (porta 5432), NÃO o "Transaction pooler" (porta 6543) — o app usa
# um Pool próprio (pg.Pool) e o modo transaction não sustenta bem sessões
# longas/prepared statements. Formato do Supabase:
#   postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:SENHA@HOST:5432/postgres

# [NOVO — normalmente não precisa setar] Força SSL na conexão do banco.
# O código já detecta automaticamente supabase.co / amazonaws.com / neon.tech
# / render.com e liga o SSL sozinho. Só defina DATABASE_SSL=true manualmente
# se estiver usando outro provedor gerenciado que não esteja nessa lista.
# DATABASE_SSL=true


# ── Autenticação ─────────────────────────────────────────────────────────────

# [NOVO OBRIGATÓRIO] Segredo usado para assinar os tokens JWT de login.
# NÃO reutilize o da Destrava: são bancos de usuários diferentes, e usar o
# mesmo segredo cria risco de um token de um sistema ser aceito no outro.
# Gere um novo com: openssl rand -hex 32
JWT_SECRET=

# [DECISÃO SUA] Segredos usados em integrações internas (ex: Nexus Gestão).
# Se o Casa DF vai se integrar com o Nexus da mesma forma que a Destrava faz,
# use os MESMOS valores que já estão configurados do lado do Nexus. Se for
# uma integração nova/isolada, gere segredos novos e configure nos dois lados.
INTEGRATION_SECRET=
NEXUS_INTEGRATION_SECRET=
NEXUS_DESTRAVA_INTEGRATION_SECRET=


# ── Domínio e URLs ───────────────────────────────────────────────────────────

# [NOVO OBRIGATÓRIO] Domínio público do Casa DF (usado em CORS, links de
# e-mail, metadados, etc). NÃO é o domínio da Destrava.
SITE_DOMAIN=casadf.com.br
FRONTEND_URL=https://casadf.com.br


# ── Armazenamento de arquivos (fotos de imóveis, logos, contratos em PDF) ───

# [NOVO — já vem certo no Dockerfile, não precisa setar manualmente]
# Pasta persistente onde ficam fotos de imóveis, logos de imobiliárias e PDFs
# gerados. O Dockerfile já define DATA_DIR=/var/data/casadf — o importante é
# você mapear um VOLUME PERSISTENTE do Coolify para esse caminho, senão as
# fotos e PDFs se perdem a cada deploy/restart do container.
# DATA_DIR=/var/data/casadf


# ── PDF (Puppeteer/Chromium) ─────────────────────────────────────────────────

# [REUTILIZAR — já vem certo no Dockerfile] Caminho do Chromium instalado
# na imagem Docker. Não precisa setar manualmente na maioria dos casos.
# CHROMIUM_PATH=/usr/bin/chromium


# ── IA (assistente / futuras automações) ─────────────────────────────────────

# [REUTILIZAR] Pode usar a mesma chave Gemini da Destrava — é só uma chave
# de API, não tem nada específico do sistema de crédito nela.
GEMINI_API_KEY=
GEMINI_API_URL=


# ── Consulta de CNPJ (mantido caso o Casa DF continue com a frente de
#    assessoria de crédito empresarial, além do imobiliário) ────────────────

# [REUTILIZAR]
CNPJ_API_TIMEOUT_MS=8000
CNPJ_ENABLE_OPENCNPJ=true
CPFCNPJ_ENABLED=true
OPENCNPJ_BASE_URL=


# ── Chatwoot (atendimento/WhatsApp) ──────────────────────────────────────────

# [DECISÃO SUA] Se o Casa DF vai usar a MESMA conta/inbox Chatwoot da
# Destrava (mesmo número, mesma equipe), reutilize os valores. Se você quer
# um inbox separado para leads imobiliários (recomendado, para não misturar
# atendimento de crédito com atendimento imobiliário), crie um inbox novo no
# Chatwoot e use o Account ID / Token / URL desse inbox novo.
CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_WEBHOOK_SECRET=


# ── n8n (automações) ─────────────────────────────────────────────────────────

# [NOVO — provavelmente] Você mencionou "outras tabelas do n8n": isso é
# importante esclarecer — o n8n tem o PRÓPRIO banco de dados interno (onde
# ele guarda os workflows), que é INDEPENDENTE do DATABASE_URL do Casa DF
# acima. Ou seja:
#   • Se você for rodar uma instância de n8n separada (nova) para o Casa DF,
#     essa instância terá seu próprio banco (pode até ser outro projeto no
#     mesmo Supabase, ou um Postgres separado) — isso é configurado NO N8N,
#     não aqui.
#   • Aqui no Casa DF, a única coisa que este app precisa é a URL do webhook
#     do workflow do n8n que vai RECEBER os eventos do sistema (leads,
#     visitas agendadas, etc). Se for um workflow novo, gere uma URL nova.
N8N_WEBHOOK_URL=


# ── Serviço de predição (opcional, usado só na frente de crédito) ───────────

# [OPCIONAL / REUTILIZAR se o Casa DF mantiver a frente de crédito]
PREDICAO_SERVICE_URL=


# ── Infra geral ───────────────────────────────────────────────────────────────

# [REUTILIZAR — valores padrão, não precisam mudar]
NODE_ENV=production
PORT=4000


# ============================================================================
# Variáveis de FRONTEND (Vite) — usadas em BUILD TIME, não runtime.
# Precisam estar disponíveis no momento do `vite build` (ou seja: configuradas
# como Build Variables/Build Args no Coolify, não só como env de runtime).
# ============================================================================

# [NOVO OBRIGATÓRIO] Título exibido na aba do navegador / algumas telas.
VITE_APP_TITLE=Casa DF

# [VERIFICAR — provavelmente já provisionado por vocês em outro sistema]
# Estas três variáveis parecem ser de um "portal" de login OAuth / serviço de
# mapas interno usado em outros dos seus sistemas (Nexus, Conexa, etc.), não
# são específicas de crédito vs imóveis. Confirme com o serviço que provisiona
# esses appIds se o Casa DF precisa de um VITE_APP_ID próprio e distinto do da
# Destrava, ou se pode reaproveitar.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
